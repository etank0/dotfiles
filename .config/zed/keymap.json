[
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      // --- FZF / Telescope ---
      "space f g": ["task::Spawn", { "task_name": "fzf Text Search (grep)" }],

      // --- Fixed Actions ---
      "space f o": "projects::OpenRecent",
      "space f b": "tab_switcher::Toggle",
      "space f s": "outline::Toggle",
      "ctrl-j": "workspace::ToggleBottomDock",

      // --- Navigation & Scrolling ---
      "ctrl-u": "editor::MovePageUp",
      "ctrl-d": "editor::MovePageDown",
      "shift-l": "pane::ActivateNextItem",
      "shift-h": "pane::ActivatePreviousItem",
      "space h": "workspace::ActivatePaneLeft",
      "space l": "workspace::ActivatePaneRight",
      "space k": "workspace::ActivatePaneUp",
      "space j": "workspace::ActivatePaneDown",

      // --- LSP / Coding ---
      "space c a": "editor::ToggleCodeActions",
      "space c d": "editor::Hover",
      "space l f": "editor::Format",
      "g h": "editor::FindAllReferences",
      "g o": "editor::GoToTypeDefinition",

      // --- Diagnostics ---
      "space d l": "diagnostics::Deploy",
      "space d h": "editor::Hover",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",

      // --- Git & Sidebars ---
      "ctrl-e": "project_panel::ToggleFocus",
      "space g b": "editor::ToggleGitBlameInline",

      // --- Window Management ---
      "space v": "pane::SplitRight",
      "space s": "pane::SplitDown",
      "space d d": "pane::CloseActiveItem",
      "space q": "pane::CloseActiveItem",
      "space o": "pane::CloseInactiveItems",
      "alt-w": "workspace::Reload"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "K": "editor::MoveLineUp",
      "J": "editor::MoveLineDown"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-e": "workspace::ToggleRightDock",
      "space f f": ["task::Spawn", { "task_name": "fzf File Finder" }],
      "ctrl-j": "workspace::ToggleBottomDock",
      "space g s": "git_panel::ToggleFocus",
      "space tab": ["workspace::SendKeystrokes", "ctrl-tab"],
      "shift-escape": "workspace::ClearAllNotifications"
    }
  }
]
