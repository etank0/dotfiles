#!/bin/bash

set -euo pipefail

CONFIG_FILE="$HOME/.config/dotpkgr/dotpkgr.conf"
BASE_DIR="${DOTFILES_DIR:-$HOME/mygithub/dotfiles}"
SCRIPTS_DIR="${BASE_DIR}/scripts/setup"
PACKAGES_DIR="${SCRIPTS_DIR}/packages"

usage() {
    cat <<EOF
Usage: dotpkgr <command> [options]

Commands:
  install [--distro <distro>] <target>
      Run a target script.
  add [--soft] <target> <pkg> [pkg...]
      Add packages and install them.
  remove [--soft] <target> <pkg> [pkg...]
      Remove packages and uninstall them.
  list
      Show all available targets.
  link <item>
      Link dotfiles to home directory.
      Items: configs

Targets:
EOF
    print_targets
    cat <<EOF

Options:
  --distro <distro>  Required for OS targets
                     and os_verification tools.
  --soft           Edit the package list only,
                     do not run install/uninstall.

Examples:
  dotpkgr add fedora htop vim git
  dotpkgr add flatpak com.app1 com.app2
  dotpkgr remove fedora htop vim
  dotpkgr remove flatpak com.app.Name
  dotpkgr add --soft fedora vim
  dotpkgr link configs
EOF
    exit 1
}

# Read config: name|script|os_verification
read_config() {
    while IFS='|' read -r name script os_verify; do
        [[ -z "$name" || "$name" == \#* ]] && continue
        echo "${name}|${script}|${os_verify}"
    done < "$CONFIG_FILE"
}

print_targets() {
    while IFS='|' read -r name script os_verify; do
        local pkg_file="${PACKAGES_DIR}/${name}.txt"
        local suffix=""
        [[ "$os_verify" == "true" ]] \
            && suffix=" (requires --distro)"

        if [[ -f "$pkg_file" ]]; then
            local count
            count=$(grep -c '.' "$pkg_file")
            printf "  %-16s %s (%d packages)%s\n" \
                "$name" "$script" "$count" "$suffix"
        else
            printf "  %-16s %s%s\n" \
                "$name" "$script" "$suffix"
        fi
    done < <(read_config)
}

# Validate target exists in config
# Sets: VALIDATE_SCRIPT, VALIDATE_NEEDS_DISTRO
validate_target() {
    local target="$1"
    VALIDATE_SCRIPT=""
    VALIDATE_NEEDS_DISTRO=false

    while IFS='|' read -r name script os_verify; do
        [[ -z "$name" || "$name" == \#* ]] && continue
        if [[ "$name" == "$target" ]]; then
            VALIDATE_SCRIPT="$script"
            if [[ "$os_verify" == "true" ]]; then
                VALIDATE_NEEDS_DISTRO=true
            fi
            return 0
        fi
    done < <(read_config)

    echo "[dotpkgr] Unknown target: '$target'"
    echo "  Run 'dotpkgr list' for available targets."
    return 1
}

# Run install/uninstall for a single package
# Args: target package action (install|remove)
run_package_action() {
    local target="$1" package="$2" action="$3"

    case "$target" in
        fedora)
            if [[ "$action" == "install" ]]; then
                sudo dnf install -y "$package"
            else
                sudo dnf remove -y "$package"
            fi
            ;;
        arch)
            if [[ "$action" == "install" ]]; then
                sudo pacman -S --noconfirm "$package"
            else
                sudo pacman -R --noconfirm "$package"
            fi
            ;;
        debian)
            if [[ "$action" == "install" ]]; then
                sudo apt install -y "$package"
            else
                sudo apt remove -y "$package"
            fi
            ;;
        flatpak)
            if [[ "$action" == "install" ]]; then
                flatpak install -y flathub "$package"
            else
                flatpak uninstall -y "$package"
            fi
            ;;
        vscode)
            if [[ "$action" == "install" ]]; then
                code --install-extension "$package"
            else
                code --uninstall-extension "$package"
            fi
            ;;
        *)
            echo "[dotpkgr] Cannot $action '$package'"
            echo "  for target '$target'."
            echo "  Run 'dotpkgr install $target'"
            echo "  to apply changes manually."
            return 1
            ;;
    esac
}

# Parse subcommand
[[ $# -eq 0 ]] && usage

SUBCOMMAND="$1"
shift

case "$SUBCOMMAND" in
    --help|-h) usage ;;
    list) print_targets; exit 0 ;;
    link)
        LINK_ITEM="${1:-}"
        shift || true

        case "$LINK_ITEM" in
            configs)
                LINK_SCRIPT="${SCRIPTS_DIR}/utils/link-config.sh"
                if [[ ! -x "$LINK_SCRIPT" ]]; then
                    echo "[dotpkgr] Script not found:"
                    echo "  $LINK_SCRIPT"
                    exit 1
                fi
                "$LINK_SCRIPT"
                exit 0
                ;;
            "")
                echo "[dotpkgr] Usage:"
                echo "  dotpkgr link <item>"
                echo ""
                echo "Items:"
                echo "  configs   Symlink .config/"
                exit 1
                ;;
            *)
                echo "[dotpkgr] Unknown item: '$LINK_ITEM'"
                echo "  Run 'dotpkgr link' for usage."
                exit 1
                ;;
        esac
        ;;
    install|add|remove) ;;
    *)
        echo "[dotpkgr] Unknown command: $SUBCOMMAND"
        usage
        ;;
esac

# Parse args
DISTRO=""
COMMAND=""
NO_RUN=false
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --distro) DISTRO="$2"; shift 2 ;;
        --soft) NO_RUN=true; shift ;;
        -*) echo "[dotpkgr] Unknown option: $1"; usage ;;
        *)
            if [[ -z "$COMMAND" ]]; then
                COMMAND="$1"
            else
                EXTRA_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

# Handle 'add' subcommand
if [[ "$SUBCOMMAND" == "add" ]]; then
    if [[ -z "$COMMAND" ]]; then
        echo "[dotpkgr] Usage:"
        echo "  dotpkgr add <target> <pkg> [pkg...]"
        exit 1
    fi

    TARGET="$COMMAND"

    if [[ ${#EXTRA_ARGS[@]} -eq 0 ]]; then
        echo "[dotpkgr] Usage:"
        echo "  dotpkgr add <target> <pkg> [pkg...]"
        exit 1
    fi

    validate_target "$TARGET" || exit 1

    PKG_FILE="${PACKAGES_DIR}/${TARGET}.txt"

    if [[ ! -f "$PKG_FILE" ]]; then
        echo "[dotpkgr] No package list for '$TARGET':"
        echo "  $PKG_FILE"
        exit 1
    fi

    # Snapshot for rollback
    PKG_SNAPSHOT=$(mktemp)
    cp "$PKG_FILE" "$PKG_SNAPSHOT"
    trap 'cp "$PKG_SNAPSHOT" "$PKG_FILE"; rm -f "$PKG_SNAPSHOT"' \
        ERR

    added=0
    skipped=0
    for PACKAGE in "${EXTRA_ARGS[@]}"; do
        if grep -qxF "$PACKAGE" "$PKG_FILE"; then
            echo "[dotpkgr] '$PACKAGE' already in $TARGET."
            skipped=$((skipped + 1))
            continue
        fi

        echo "$PACKAGE" >> "$PKG_FILE"
        echo "[dotpkgr] Added '$PACKAGE' to $TARGET"
        added=$((added + 1))
    done

    sort -u -o "$PKG_FILE" "$PKG_FILE"

    # Install each new package
    if [[ "$NO_RUN" == "false" && $added -gt 0 ]]; then
        failed=0
        for PACKAGE in "${EXTRA_ARGS[@]}"; do
            # Skip if it was already in the list
            if grep -qxvf "$PKG_SNAPSHOT" "$PKG_FILE" \
                | grep -qxF "$PACKAGE"; then
                continue
            fi
            echo "[dotpkgr] Installing '$PACKAGE'..."
            if ! run_package_action "$TARGET" \
                "$PACKAGE" install; then
                echo "[dotpkgr] Failed to install"
                echo "  '$PACKAGE'. Rolling back."
                failed=$((failed + 1))
            fi
        done

        if [[ $failed -gt 0 ]]; then
            cp "$PKG_SNAPSHOT" "$PKG_FILE"
            rm -f "$PKG_SNAPSHOT"
            trap - ERR
            echo "[dotpkgr] Rolled back changes."
            exit 1
        fi
    fi

    rm -f "$PKG_SNAPSHOT"
    trap - ERR

    echo "[dotpkgr] Done. $added added, $skipped skipped."
    exit 0
fi

# Handle 'remove' subcommand
if [[ "$SUBCOMMAND" == "remove" ]]; then
    if [[ -z "$COMMAND" ]]; then
        echo "[dotpkgr] Usage:"
        echo "  dotpkgr remove <target> <pkg> [pkg...]"
        exit 1
    fi

    TARGET="$COMMAND"

    if [[ ${#EXTRA_ARGS[@]} -eq 0 ]]; then
        echo "[dotpkgr] Usage:"
        echo "  dotpkgr remove <target> <pkg> [pkg...]"
        exit 1
    fi

    validate_target "$TARGET" || exit 1

    PKG_FILE="${PACKAGES_DIR}/${TARGET}.txt"

    if [[ ! -f "$PKG_FILE" ]]; then
        echo "[dotpkgr] No package list for '$TARGET':"
        echo "  $PKG_FILE"
        exit 1
    fi

    # Validate all packages exist first
    for PACKAGE in "${EXTRA_ARGS[@]}"; do
        if ! grep -qxF "$PACKAGE" "$PKG_FILE"; then
            echo "[dotpkgr] '$PACKAGE' not in $TARGET."
            echo "  Current packages:"
            sed 's/^/    /' "$PKG_FILE"
            exit 1
        fi
    done

    # Snapshot for rollback
    PKG_SNAPSHOT=$(mktemp)
    cp "$PKG_FILE" "$PKG_SNAPSHOT"
    trap 'cp "$PKG_SNAPSHOT" "$PKG_FILE"; rm -f "$PKG_SNAPSHOT"' \
        ERR

    # Uninstall each package first, then remove
    if [[ "$NO_RUN" == "false" ]]; then
        failed=0
        for PACKAGE in "${EXTRA_ARGS[@]}"; do
            echo "[dotpkgr] Uninstalling '$PACKAGE'..."
            if ! run_package_action "$TARGET" \
                "$PACKAGE" remove; then
                echo "[dotpkgr] Failed to uninstall"
                echo "  '$PACKAGE'. Rolling back."
                failed=$((failed + 1))
            fi
        done

        if [[ $failed -gt 0 ]]; then
            cp "$PKG_SNAPSHOT" "$PKG_FILE"
            rm -f "$PKG_SNAPSHOT"
            trap - ERR
            echo "[dotpkgr] Rolled back changes."
            exit 1
        fi
    fi

    # Remove from list
    for PACKAGE in "${EXTRA_ARGS[@]}"; do
        sed -i "/^${PACKAGE}$/d" "$PKG_FILE"
        echo "[dotpkgr] Removed '$PACKAGE' from $TARGET"
    done

    rm -f "$PKG_SNAPSHOT"
    trap - ERR

    echo "[dotpkgr] Done. ${#EXTRA_ARGS[@]} removed."
    exit 0
fi

# Validate --distro
if [[ -n "$DISTRO" ]]; then
    VALID=false
    while IFS='|' read -r name script os_verify; do
        [[ -z "$name" || "$name" == \#* ]] && continue
        if [[ "$name" == "$DISTRO" \
                && "$script" == os/* ]]; then
            VALID=true
            break
        fi
    done < <(read_config)

    if [[ "$VALID" != "true" ]]; then
        echo "[dotpkgr] Invalid --distro: '$DISTRO'"
        exit 1
    fi
fi

# Fallback: --distro alone means install that distro
if [[ -z "$COMMAND" ]]; then
    if [[ -n "$DISTRO" ]]; then
        COMMAND="$DISTRO"
    else
        echo "[dotpkgr] Missing target."
        usage
    fi
fi

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "[dotpkgr] Config not found:"
    echo "  $CONFIG_FILE"
    exit 1
fi

# Resolve script path and os_verification
SCRIPT_REL=""
NEEDS_DISTRO=false
while IFS='|' read -r name script os_verify; do
    [[ -z "$name" || "$name" == \#* ]] && continue
    if [[ "$name" == "$COMMAND" ]]; then
        SCRIPT_REL="$script"
        if [[ "$os_verify" == "true" ]]; then
            NEEDS_DISTRO=true
        fi
        break
    fi
done < <(read_config)

if [[ -z "$SCRIPT_REL" ]]; then
    echo "[dotpkgr] Unknown target: '$COMMAND'"
    exit 1
fi

# OS scripts always need distro
[[ "$SCRIPT_REL" == os/* ]] && NEEDS_DISTRO=true

SCRIPT_PATH="${SCRIPTS_DIR}/${SCRIPT_REL}"

if [[ "$NEEDS_DISTRO" == true ]]; then
    if [[ -z "$DISTRO" ]]; then
        echo "[dotpkgr] --distro is required"
        echo "  for '$COMMAND'."
        exit 1
    fi
    if [[ "$SCRIPT_REL" == os/* \
            && "$COMMAND" != "$DISTRO" ]]; then
        echo "[dotpkgr] Conflict:"
        echo "  '$COMMAND' is not the OS target"
        echo "  for --distro '$DISTRO'."
        exit 1
    fi
fi

if [[ ! -x "$SCRIPT_PATH" ]]; then
    echo "[dotpkgr] Script not executable:"
    echo "  $SCRIPT_PATH"
    exit 1
fi

echo "[dotpkgr] Running: $SCRIPT_PATH"
"$SCRIPT_PATH"
